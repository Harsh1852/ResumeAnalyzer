# Copy to .env.local and fill in values from CDK deploy outputs

# Auth API URL (ResumeAnalyzerAuth output: AuthApiUrl)
VITE_AUTH_API_URL=https://<_API_ID_>.execute-api.us-east-1.amazonaws.com/prod/

# Upload API URL (ResumeAnalyzerUpload output: AppApiUrl)
VITE_APP_API_URL=https://<_API_ID_>.execute-api.us-east-1.amazonaws.com/prod/

# Results API URL (ResumeAnalyzerResults output: ResultsApiUrl)
VITE_RESULTS_API_URL=https://<_API_ID_>.execute-api.us-east-1.amazonaws.com/prod/